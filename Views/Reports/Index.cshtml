@model IEnumerable<MunicipalityManagementSystem.Models.Report>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Reports Management";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="mb-0">Reports</h1>
            <p class="text-secondary mt-1">View and manage all generated reports</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-file-earmark-plus"></i> New Report
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="p-4 text-center">
                    <p class="text-secondary mb-0">No reports found. <a asp-action="Create">Create one now</a>.</p>
                </div>
            }
            else
            {
                <table id="dataTable" class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Report Type</th>
                            <th>Citizen</th>
                            <th>Details</th>
                            <th>Submission Date</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.ReportType</strong></td>
                                <td>@item.Citizen?.FullName</td>
                                <td><span class="text-secondary">@(item.Details?.Length > 50 ? item.Details.Substring(0, 50) + "..." : item.Details)</span></td>
                                <td>@item.SubmissionDate.ToShortDateString()</td>
                                <td>
                                    @{
                                        var reportBadgeClass = item.Status?.ToLower() switch
                                        {
                                            "resolved" => "bg-success text-white",
                                            "under review" => "bg-warning text-dark",
                                            "rejected" => "bg-danger text-white",
                                            _ => "bg-secondary text-white"
                                        };
                                    }
                                    <span class="badge @reportBadgeClass">@item.Status</span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.ReportID" class="btn btn-sm btn-secondary" title="View details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.ReportID" class="btn btn-sm btn-primary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <form id="deleteReportForm_@item.ReportID" asp-action="Delete" asp-route-id="@item.ReportID" method="post" style="display: none;">
                                                @Html.AntiForgeryToken()
                                            </form>
                                            <button type="button" class="btn btn-sm btn-danger sa-delete-report" data-id="@item.ReportID" data-type="@item.ReportType" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {
            $("#dataTable").DataTable({
                pageLength: 10,
                order: [[3, "desc"]],
                language: {
                    search: "Search reports:",
                    lengthMenu: "Show _MENU_ reports",
                    info: "Showing _START_ to _END_ of _TOTAL_ reports",
                    emptyTable: "No reports found."
                },
                columnDefs: [
                    { orderable: false, targets: -1 }
                ]
            });
        });

        // SweetAlert2 for report deletion
        document.querySelectorAll('.sa-delete-report').forEach(function(button) {
            button.addEventListener('click', function(e) {
                e.preventDefault();
                const reportId = this.getAttribute('data-id');
                const reportType = this.getAttribute('data-type');

                Swal.fire({
                    title: 'Delete Report?',
                    text: 'You are about to delete the report ' + reportType + '. This cannot be undone.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#C53030',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, delete it',
                    cancelButtonText: 'Cancel'
                }).then(function(result) {
                    if (result.isConfirmed) {
                        document.getElementById('deleteReportForm_' + reportId).submit();
                    }
                });
            });
        });
    </script>
}
