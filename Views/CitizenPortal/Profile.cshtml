@model MunicipalityManagementSystem.Models.Citizen

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "My Profile";
}

@* ══════════════════════════════════════════════════════════
   Mini Stat Strip
══════════════════════════════════════════════════════════ *@
<div class="row g-3 mb-4">

    <div class="col-4">
        <div class="info-box shadow-sm mb-0">
            <span class="info-box-icon" style="background:var(--sa-blue);">
                <i class="bi bi-clipboard2-fill text-white"></i>
            </span>
            <div class="info-box-content">
                <span class="info-box-text">Total Requests</span>
                <span class="info-box-number">
                    <span id="statTotal">@ViewData["TotalRequests"]</span>
                </span>
            </div>
        </div>
    </div>

    <div class="col-4">
        <div class="info-box shadow-sm mb-0">
            <span class="info-box-icon" style="background:var(--sa-gold);">
                <i class="bi bi-hourglass-split text-white"></i>
            </span>
            <div class="info-box-content">
                <span class="info-box-text">Pending</span>
                <span class="info-box-number">
                    <span id="statPending">@ViewData["PendingRequests"]</span>
                </span>
            </div>
        </div>
    </div>

    <div class="col-4">
        <div class="info-box shadow-sm mb-0">
            <span class="info-box-icon" style="background:var(--sa-green);">
                <i class="bi bi-check-circle-fill text-white"></i>
            </span>
            <div class="info-box-content">
                <span class="info-box-text">Completed</span>
                <span class="info-box-number">
                    <span id="statCompleted">@ViewData["CompletedRequests"]</span>
                </span>
            </div>
        </div>
    </div>

</div>

@* ══════════════════════════════════════════════════════════
   Two-column layout: Account Info (read-only) + Contact & Address (editable)
══════════════════════════════════════════════════════════ *@
<div class="row g-4 mb-4">

    @* Left — Account Information *@
    <div class="col-md-5">
        <div class="card shadow-sm h-100">
            <div class="card-header text-white fw-semibold"
                 style="background:var(--sa-blue);">
                <i class="bi bi-person-circle me-2"></i>Account Information
            </div>
            <div class="card-body">

                <div class="mb-3">
                    <label class="form-label text-muted small mb-1">Full Name</label>
                    <p class="fw-semibold mb-0">@Model.FullName</p>
                </div>
                <hr class="my-2" />

                <div class="mb-3">
                    <label class="form-label text-muted small mb-1">Email</label>
                    <p class="fw-semibold mb-0">@Model.Email</p>
                </div>
                <hr class="my-2" />

                <div class="mb-3">
                    <label class="form-label text-muted small mb-1">Date of Birth</label>
                    <p class="fw-semibold mb-0">
                        @(Model.DateOfBirth.HasValue
                                                ? Model.DateOfBirth.Value.ToString("yyyy/MM/dd")
                                                : "Not provided")
                    </p>
                </div>
                <hr class="my-2" />

                <div class="mb-0">
                    <label class="form-label text-muted small mb-1">Member Since</label>
                    <p class="fw-semibold mb-0">
                        @Model.RegistrationDate.ToString("yyyy/MM/dd")
                    </p>
                </div>

            </div>
        </div>
    </div>

    @* Right — Contact & Address (editable) *@
    <div class="col-md-7">
        <div class="card shadow-sm h-100">
            <div class="card-header text-white fw-semibold"
                 style="background:var(--sa-green);">
                <i class="bi bi-pencil-square me-2"></i>Contact &amp; Address
            </div>
            <div class="card-body">

                <form asp-action="Profile" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="CitizenID" value="@Model.CitizenID" />

                    <div class="row g-3">

                        <div class="col-md-8">
                            <label class="form-label small fw-semibold">Street Name</label>
                            <input type="text" name="streetName"
                                   value="@Model.StreetName"
                                   class="form-control form-control-sm" required />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Suburb</label>
                            <input type="text" name="suburb"
                                   value="@Model.Suburb"
                                   class="form-control form-control-sm" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">City</label>
                            <input type="text" name="city"
                                   value="@Model.City"
                                   class="form-control form-control-sm" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Postal Code</label>
                            <input type="text" name="postalCode"
                                   value="@Model.PostalCode"
                                   class="form-control form-control-sm" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Phone Number</label>
                            <input type="text" name="phoneNumber"
                                   value="@Model.PhoneNumber"
                                   class="form-control form-control-sm" required />
                        </div>

                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-sm"
                                style="background:var(--sa-green);color:#fff;">
                            <i class="bi bi-save me-1"></i>Save Changes
                        </button>
                    </div>

                </form>

            </div>
        </div>
    </div>

</div>

@* ══════════════════════════════════════════════════════════
   Notifications Card
══════════════════════════════════════════════════════════ *@
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header text-white fw-semibold"
                 style="background:var(--sa-blue);">
                <i class="bi bi-bell-fill me-2" style="color:var(--sa-gold);"></i>Notifications
            </div>
            <div class="card-body d-flex justify-content-between align-items-center">
                <p class="mb-0 text-muted">
                    View and manage your service request notifications.
                </p>
                <a asp-controller="Notifications" asp-action="Index"
                   class="btn btn-sm"
                   style="background:var(--sa-blue);color:#fff;">
                    <i class="bi bi-bell me-1"></i>My Notifications
                </a>
            </div>
        </div>
    </div>
</div>

@* ══════════════════════════════════════════════════════════
   Danger Zone
══════════════════════════════════════════════════════════ *@
<div class="row g-4">
    <div class="col-12">
        <div class="card shadow-sm border-danger">
            <div class="card-header text-white fw-semibold"
                 style="background:var(--sa-danger);">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>Danger Zone
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">
                    Deleting your account is <strong>permanent and cannot be undone.</strong>
                    Your citizen record will be kept for administrative purposes
                    but your login access will be removed immediately.
                </p>
                <a asp-action="DeleteAccount" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-trash me-1"></i>Delete My Account
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            // CountUp.js — animate mini stat strip
            var stats = [
                { id: "statTotal",     val: @ViewData["TotalRequests"] },
                { id: "statPending",   val: @ViewData["PendingRequests"] },
                { id: "statCompleted", val: @ViewData["CompletedRequests"] }
            ];

            stats.forEach(function (s) {
                var el = document.getElementById(s.id);
                if (el && s.val > 0) {
                    new countUp.CountUp(s.id, s.val, {
                        duration: 1.8,
                        useEasing: true
                    }).start();
                }
            });
        })();
    </script>
}
