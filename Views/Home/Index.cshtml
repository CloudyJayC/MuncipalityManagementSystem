@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="p-5 mb-4 bg-light rounded-3 shadow-sm">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="display-5">Welcome to Municipality Management System</h1>
                <p class="lead mt-3">
                    Manage citizens, service requests, staff, and reports for your municipality.
                </p>
                <p class="text-secondary">
                    A web application built with ASP.NET Core for local government administration.
                </p>
                <hr class="my-4">
                <a class="btn btn-primary btn-lg me-3" asp-controller="ServiceRequests" asp-action="Index" role="button">
                    <i class="bi bi-clipboard-check"></i> View Service Requests
                </a>
                @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                {
                    <a class="btn btn-secondary btn-lg" asp-controller="Citizens" asp-action="Index" role="button">
                        <i class="bi bi-people"></i> Manage Citizens
                    </a>
                }
            </div>
            <div class="col-md-4 text-center">
                <i class="bi bi-building" style="font-size: 6rem; color: var(--sa-blue); opacity: 0.7;"></i>
            </div>
        </div>
    </div>

    <div class="row mt-5 mb-5">
        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
        {
            <div class="col-md-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-people" style="font-size: 2rem; color: var(--sa-blue);"></i>
                            <h5 class="card-title ms-3 mb-0">Citizen Management</h5>
                        </div>
                        <p class="card-text text-secondary">
                            Create, update, and manage citizen records with comprehensive details including contact information and registration dates.
                        </p>
                        <a asp-controller="Citizens" asp-action="Index" class="text-primary fw-semibold">Manage Citizens →</a>
                    </div>
                </div>
            </div>
        }

        <div class="col-md-6 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-clipboard-check" style="font-size: 2rem; color: var(--sa-green);"></i>
                        <h5 class="card-title ms-3 mb-0">Service Requests</h5>
                    </div>
                    <p class="card-text text-secondary">
                        Track and manage all citizen service requests with status updates. Improve response times and service delivery efficiency.
                    </p>
                    <a asp-controller="ServiceRequests" asp-action="Index" class="text-primary fw-semibold">View Requests →</a>
                </div>
            </div>
        </div>

        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
        {
            <div class="col-md-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-briefcase" style="font-size: 2rem; color: var(--sa-gold);"></i>
                            <h5 class="card-title ms-3 mb-0">Staff Directory</h5>
                        </div>
                        <p class="card-text text-secondary">
                            Maintain a comprehensive database of municipal staff with department assignments, positions, and contact information.
                        </p>
                        <a asp-controller="Staff" asp-action="Index" class="text-primary fw-semibold">View Staff →</a>
                    </div>
                </div>
            </div>
        }

        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
        {
            <div class="col-md-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-file-earmark-text" style="font-size: 2rem; color: var(--sa-danger);"></i>
                            <h5 class="card-title ms-3 mb-0">Reports</h5>
                        </div>
                        <p class="card-text text-secondary">
                            Generate and track comprehensive reports related to citizens and municipal operations for data-driven decision making.
                        </p>
                        <a asp-controller="Reports" asp-action="Index" class="text-primary fw-semibold">View Reports →</a>
                    </div>
                </div>
            </div>
        }

        @if (User.IsInRole("Admin"))
        {
            <div class="col-md-6 mb-3">
                <div class="card h-100" style="border-top: 3px solid var(--sa-blue);">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-shield-lock" style="font-size: 2rem; color: var(--sa-blue);"></i>
                            <h5 class="card-title ms-3 mb-0">Admin Portal</h5>
                        </div>
                        <p class="card-text text-secondary">
                            Manage user accounts, create staff logins, and view system-wide statistics from the admin dashboard.
                        </p>
                        <a asp-controller="Admin" asp-action="Dashboard" class="text-primary fw-semibold">Go to Admin Portal →</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
