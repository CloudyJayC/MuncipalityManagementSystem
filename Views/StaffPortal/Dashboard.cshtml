@model IEnumerable<MunicipalityManagementSystem.Models.ServiceRequest>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Staff Dashboard";
}

<div class="container mt-4">

    <!-- Welcome Header -->
    <div class="mb-4">
        <h1 class="mb-0">Welcome, @ViewData["StaffName"]</h1>
        <p class="text-secondary mt-1">Here's an overview of current municipal operations.</p>
    </div>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-hourglass-split me-3" style="font-size: 2rem; color: #C9A227;"></i>
                    <div>
                        <p class="text-secondary mb-0" style="font-size: 0.85rem;">Pending Requests</p>
                        <h3 class="mb-0">@ViewData["PendingCount"]</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-arrow-repeat me-3" style="font-size: 2rem; color: #002395;"></i>
                    <div>
                        <p class="text-secondary mb-0" style="font-size: 0.85rem;">In Progress</p>
                        <h3 class="mb-0">@ViewData["InProgressCount"]</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-check-circle me-3" style="font-size: 2rem; color: #007A4D;"></i>
                    <div>
                        <p class="text-secondary mb-0" style="font-size: 0.85rem;">Completed</p>
                        <h3 class="mb-0">@ViewData["CompletedCount"]</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="card h-100">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-people me-3" style="font-size: 2rem; color: #002395;"></i>
                    <div>
                        <p class="text-secondary mb-0" style="font-size: 0.85rem;">Total Citizens</p>
                        <h3 class="mb-0">@ViewData["TotalCitizens"]</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="card h-100">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-file-earmark-text me-3" style="font-size: 2rem; color: #C53030;"></i>
                    <div>
                        <p class="text-secondary mb-0" style="font-size: 0.85rem;">Total Reports</p>
                        <h3 class="mb-0">@ViewData["TotalReports"]</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Service Requests -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-clock-history"></i> Recent Service Requests</span>
            <a asp-controller="ServiceRequests" asp-action="Index" class="btn btn-sm btn-primary">View All</a>
        </div>
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="p-4 text-center">
                    <p class="text-secondary mb-0">No service requests yet.</p>
                </div>
            }
            else
            {
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Service Type</th>
                            <th>Citizen</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.ServiceType</strong></td>
                                <td>@item.Citizen?.FullName</td>
                                <td>@item.RequestDate.ToShortDateString()</td>
                                <td>
                                    @{
                                        var badgeClass = item.Status?.ToLower() switch
                                        {
                                                            "completed" => "bg-success text-white",
                                                            "pending" => "bg-warning text-dark",
                                                            "in progress" => "bg-primary text-white",
                                                            "cancelled" => "bg-secondary text-white",
                                            _ => "bg-light text-dark"
                                        };
                                    }
                                    <span class="badge @badgeClass">@item.Status</span>
                                </td>
                                <td class="text-center">
                                    <a asp-controller="ServiceRequests" asp-action="Edit" asp-route-id="@item.RequestID"
                                       class="btn btn-sm btn-outline-primary" title="Update status">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

</div>
