@model IEnumerable<MunicipalityManagementSystem.Models.AdminUserViewModel>
@using Microsoft.AspNetCore.Identity
@inject UserManager<MunicipalityManagementSystem.Models.ApplicationUser> UserManager

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "User Management";
    var currentUserId = UserManager.GetUserId(User);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold" style="color: var(--sa-blue);">
        <i class="bi bi-people-fill me-2"></i>User Management
    </h1>
    <a asp-controller="Admin" asp-action="CreateStaff" class="btn btn-success">
        <i class="bi bi-person-plus me-1"></i> Create Staff Account
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="p-4 text-center text-muted">No users found.</div>
        }
        else
        {
            <div class="table-responsive">
            <table id="dataTable" class="table table-hover mb-0">
                <thead style="background-color: var(--sa-blue); color: white;">
                            <tr>
                        <th class="ps-3">Full Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Linked Record</th>
                        <th class="text-center pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td class="ps-3 align-middle">@u.FullName</td>
                            <td class="align-middle">@u.Email</td>
                            <td class="align-middle">
                                @{
                                    var badgeStyle = u.Role switch
                                    {
                                        "Admin" => "background: var(--sa-danger);",
                                        "Staff" => "background: var(--sa-blue);",
                                        "Citizen" => "background: var(--sa-green);",
                                        _ => "background:#6c757d;"
                                    };
                                }
                                <span class="badge" style="@badgeStyle">@u.Role</span>
                            </td>
                            <td class="align-middle">
                                @(u.LinkedName ?? "None")
                            </td>
                            <td class="text-center align-middle pe-3">
                                @if (u.Id != currentUserId)
                                {
                                    <form id="deleteUserForm_@u.Id"
                                          asp-controller="Admin"
                                          asp-action="DeleteUser"
                                          method="post"
                                          style="display: none;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@u.Id" />
                                    </form>
                                    <button type="button"
                                            class="btn btn-sm btn-danger sa-delete-user"
                                            data-id="@u.Id"
                                            data-email="@u.Email"
                                            data-name="@u.FullName">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">You</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
    </a>
</div>

@section Scripts {
<script>
    $(document).ready(function () {
        $("#dataTable").DataTable({
            pageLength: 10,
            language: {
                search: "Search users:",
                lengthMenu: "Show _MENU_ users",
                info: "Showing _START_ to _END_ of _TOTAL_ users",
                emptyTable: "No users found."
            },
            columnDefs: [
                { orderable: false, targets: -1 }
            ]
        });
    });

    // SweetAlert2 for user deletion
    document.querySelectorAll('.sa-delete-user').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var id = this.getAttribute('data-id');
            var email = this.getAttribute('data-email');
            var name = this.getAttribute('data-name');

            Swal.fire({
                title: 'Delete User Account?',
                html: 'You are about to permanently delete <strong>' + name + '</strong> (' + email + ').<br><br>Their citizen or staff record will be detached but preserved.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#C53030',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, delete account',
                cancelButtonText: 'Cancel'
            }).then(function(result) {
                if (result.isConfirmed) {
                    document.getElementById('deleteUserForm_' + id).submit();
                }
            });
        });
    });
</script>
}
        // SweetAlert2 for user deletion
        document.querySelectorAll('.sa-delete-user').forEach(function(button) {
            button.addEventListener('click', function(e) {
                e.preventDefault();
                const userId = this.getAttribute('data-id');
                const userEmail = this.getAttribute('data-email');
                const userName = this.getAttribute('data-name');

                Swal.fire({
                    title: 'Delete User Account?',
                    html: 'You are about to permanently delete <strong>' + userName + '</strong> (' + userEmail + ').<br><br>Their citizen or staff record will be detached but preserved.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#C53030',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, delete account',
                    cancelButtonText: 'Cancel'
                }).then(function(result) {
                    if (result.isConfirmed) {
                        document.getElementById('deleteUserForm_' + userId).submit();
                    }
                });
            });
        });
    </script>
}
