@model IEnumerable<MunicipalityManagementSystem.Models.ServiceRequest>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Service Requests";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="mb-0">Service Requests</h1>
            <p class="text-secondary mt-1">Track and manage citizen service requests</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> New Request
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="p-4 text-center">
                    <p class="text-secondary mb-0">No service requests found. <a asp-action="Create">Create one now</a>.</p>
                </div>
            }
            else
            {
                <table id="dataTable" class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Service Type</th>
                            <th>Request Date</th>
                            <th>Status</th>
                            <th>Citizen</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.ServiceType</strong></td>
                                <td>@item.RequestDate.ToShortDateString()</td>
                                <td>
                                    @{
                                        var badgeClass = item.Status?.ToLower() switch
                                        {
                                                            "completed" => "bg-success",
                                                            "pending" => "bg-warning text-dark",
                                                            "in progress" => "bg-primary",
                                                            "cancelled" => "bg-secondary",
                                            _ => "bg-light text-dark"
                                        };
                                    }
                                    <span class="badge @badgeClass">@item.Status</span>
                                </td>
                                <td>@item.Citizen?.FullName</td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">

                                        @* Everyone gets Details *@
                                        <a asp-action="Details" asp-route-id="@item.RequestID"
                                           class="btn btn-sm btn-outline-secondary" title="View details">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                                        {
                                            @* Admin and Staff get Edit *@
                                            <a asp-action="Edit" asp-route-id="@item.RequestID"
                                               class="btn btn-sm btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }

                                        @if (User.IsInRole("Admin"))
                                        {
                                            @* Admin only gets Delete *@
                                            <form id="deleteRequestForm_@item.RequestID" asp-action="Delete" asp-route-id="@item.RequestID" method="post" style="display: none;">
                                                @Html.AntiForgeryToken()
                                            </form>
                                            <button type="button" class="btn btn-sm btn-outline-danger sa-delete-request" data-id="@item.RequestID" data-type="@item.ServiceType" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }

                                        @if (User.IsInRole("Citizen") && item.Status == "Pending")
                                        {
                                            @* Citizens can only cancel Pending requests *@
                                            <form id="cancelRequestForm_@item.RequestID" asp-action="Cancel" asp-route-id="@item.RequestID" method="post" style="display: none;">
                                                @Html.AntiForgeryToken()
                                            </form>
                                            <button type="button" class="btn btn-sm btn-outline-warning sa-cancel-request" data-id="@item.RequestID" data-type="@item.ServiceType" title="Cancel request">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        }

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {
            $("#dataTable").DataTable({
                pageLength: 10,
                order: [[2, "desc"]],
                language: {
                    search: "Search requests:",
                    lengthMenu: "Show _MENU_ requests",
                    info: "Showing _START_ to _END_ of _TOTAL_ requests",
                    emptyTable: "No service requests found."
                },
                columnDefs: [
                    { orderable: false, targets: -1 }
                ]
            });
        });

        // SweetAlert2 for request deletion
        document.querySelectorAll('.sa-delete-request').forEach(function(button) {
            button.addEventListener('click', function(e) {
                e.preventDefault();
                const requestId = this.getAttribute('data-id');
                const serviceType = this.getAttribute('data-type');

                Swal.fire({
                    title: 'Delete Request?',
                    text: 'You are about to delete the request for ' + serviceType + '. This cannot be undone.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#C53030',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, delete it',
                    cancelButtonText: 'Cancel'
                }).then(function(result) {
                    if (result.isConfirmed) {
                        document.getElementById('deleteRequestForm_' + requestId).submit();
                    }
                });
            });
        });

        // SweetAlert2 for request cancellation
        document.querySelectorAll('.sa-cancel-request').forEach(function(button) {
            button.addEventListener('click', function(e) {
                e.preventDefault();
                const requestId = this.getAttribute('data-id');
                const serviceType = this.getAttribute('data-type');

                Swal.fire({
                    title: 'Cancel Request?',
                    text: 'Cancel the request for ' + serviceType + '? This cannot be undone.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#C53030',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, cancel it',
                    cancelButtonText: 'Go Back'
                }).then(function(result) {
                    if (result.isConfirmed) {
                        document.getElementById('cancelRequestForm_' + requestId).submit();
                    }
                });
            });
        });
    </script>
}
