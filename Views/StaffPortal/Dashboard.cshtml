@model IEnumerable<MunicipalityManagementSystem.Models.ServiceRequest>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Staff Dashboard";
}

@* ═══════════════════════════════════════════════════════════
   WELCOME HEADER
   ═══════════════════════════════════════════════════════════ *@
<div class="mb-4">
    <h4 class="fw-bold" style="color: var(--sa-blue);">
        <i class="bi bi-person-badge-fill me-2"></i>Welcome, @ViewData["StaffName"]
    </h4>
    <p class="text-secondary mb-0">Here's an overview of current municipal operations.</p>
</div>

@* ═══════════════════════════════════════════════════════════
   STAT CARDS
   ═══════════════════════════════════════════════════════════ *@
<div class="row g-3 mb-4">

    <div class="col-6 col-md-4">
        <div class="info-box shadow-sm mb-0">
            <span class="info-box-icon" style="background: var(--sa-gold);">
                <i class="bi bi-hourglass-split text-white"></i>
            </span>
            <div class="info-box-content">
                <span class="info-box-text">Pending</span>
                <span class="info-box-number">
                    <span id="statPending">@ViewData["PendingCount"]</span>
                </span>
            </div>
        </div>
    </div>

    <div class="col-6 col-md-4">
        <div class="info-box shadow-sm mb-0">
            <span class="info-box-icon" style="background: var(--sa-blue);">
                <i class="bi bi-arrow-repeat text-white"></i>
            </span>
            <div class="info-box-content">
                <span class="info-box-text">In Progress</span>
                <span class="info-box-number">
                    <span id="statInProgress">@ViewData["InProgressCount"]</span>
                </span>
            </div>
        </div>
    </div>

    <div class="col-6 col-md-4">
        <div class="info-box shadow-sm mb-0">
            <span class="info-box-icon" style="background: var(--sa-green);">
                <i class="bi bi-check-circle-fill text-white"></i>
            </span>
            <div class="info-box-content">
                <span class="info-box-text">Completed</span>
                <span class="info-box-number">
                    <span id="statCompleted">@ViewData["CompletedCount"]</span>
                </span>
            </div>
        </div>
    </div>

    <div class="col-6 col-md-6">
        <div class="info-box shadow-sm mb-0">
            <span class="info-box-icon" style="background: var(--sa-blue);">
                <i class="bi bi-person-vcard-fill text-white"></i>
            </span>
            <div class="info-box-content">
                <span class="info-box-text">Total Citizens</span>
                <span class="info-box-number">
                    <span id="statCitizens">@ViewData["TotalCitizens"]</span>
                </span>
            </div>
        </div>
    </div>

    <div class="col-6 col-md-6">
        <div class="info-box shadow-sm mb-0">
            <span class="info-box-icon" style="background: var(--sa-danger);">
                <i class="bi bi-file-earmark-text-fill text-white"></i>
            </span>
            <div class="info-box-content">
                <span class="info-box-text">Total Reports</span>
                <span class="info-box-number">
                    <span id="statReports">@ViewData["TotalReports"]</span>
                </span>
            </div>
        </div>
    </div>

</div>

@* ═══════════════════════════════════════════════════════════
   RECENT SERVICE REQUESTS
   ═══════════════════════════════════════════════════════════ *@
<div class="card shadow-sm">
    <div class="card-header text-white fw-semibold d-flex justify-content-between align-items-center"
         style="background: var(--sa-blue);">
        <span><i class="bi bi-clock-history me-2"></i>Recent Service Requests</span>
        <a asp-controller="ServiceRequests" asp-action="Index"
           class="btn btn-sm btn-light" style="color: var(--sa-blue);">View All</a>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="p-4 text-center">
                <p class="text-secondary mb-0">No service requests yet.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Service Type</th>
                            <th>Citizen</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.ServiceType</strong></td>
                                <td>@item.Citizen?.FullName</td>
                                <td>@item.RequestDate.ToShortDateString()</td>
                                <td>
                                    @{
                                        var badgeClass = item.Status?.ToLower() switch
                                        {
                                            "completed" => "bg-success text-white",
                                            "pending" => "bg-warning text-dark",
                                            "in progress" => "bg-primary text-white",
                                            "cancelled" => "bg-secondary text-white",
                                            _ => "bg-light text-dark"
                                        };
                                    }
                                    <span class="badge @badgeClass">@item.Status</span>
                                </td>
                                <td class="text-center">
                                    <a asp-controller="ServiceRequests" asp-action="Edit"
                                           asp-route-id="@item.RequestID"
                                           class="btn btn-sm btn-outline-primary" title="Update status">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var stats = [
                { id: "statPending",    val: @(ViewData["PendingCount"] ?? 0) },
                { id: "statInProgress", val: @(ViewData["InProgressCount"] ?? 0) },
                { id: "statCompleted",  val: @(ViewData["CompletedCount"] ?? 0) },
                { id: "statCitizens",   val: @(ViewData["TotalCitizens"] ?? 0) },
                { id: "statReports",    val: @(ViewData["TotalReports"] ?? 0) }
            ];

            stats.forEach(function (s) {
                var el = document.getElementById(s.id);
                if (el && s.val > 0) {
                    new countUp.CountUp(s.id, s.val, {
                        duration: 1.8,
                        useEasing: true
                    }).start();
                }
            });
        })();
    </script>
}
