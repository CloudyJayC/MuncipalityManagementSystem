@model IEnumerable<MunicipalityManagementSystem.Models.Notification>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "My Notifications";
    var unreadCount = Model.Count(n => !n.IsRead);
}

@* ══════════════════════════════════════════════════════════
   Entrance animation + empty state styles
══════════════════════════════════════════════════════════ *@
@section Styles {
<style>
    @@keyframes fadeSlideIn {
        from {
            opacity: 0;
            transform: translateX(-18px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .notif-card {
        animation: fadeSlideIn 0.35s ease both;
    }

    .notif-card:nth-child(1)  { animation-delay: 0.05s; }
    .notif-card:nth-child(2)  { animation-delay: 0.10s; }
    .notif-card:nth-child(3)  { animation-delay: 0.15s; }
    .notif-card:nth-child(4)  { animation-delay: 0.20s; }
    .notif-card:nth-child(5)  { animation-delay: 0.25s; }
    .notif-card:nth-child(6)  { animation-delay: 0.30s; }
    .notif-card:nth-child(7)  { animation-delay: 0.35s; }
    .notif-card:nth-child(8)  { animation-delay: 0.40s; }
    .notif-card:nth-child(9)  { animation-delay: 0.45s; }
    .notif-card:nth-child(10) { animation-delay: 0.50s; }

    .notif-unread {
        border-left: 4px solid var(--sa-blue) !important;
    }

    .notif-read {
        opacity: 0.82;
    }

    @@keyframes pulse {
        0%, 100% { transform: scale(1);    opacity: 0.5; }
        50%       { transform: scale(1.08); opacity: 0.8; }
    }

    .empty-icon {
        animation: pulse 2.4s ease-in-out infinite;
        display: inline-block;
    }
</style>
}

@* ══════════════════════════════════════════════════════════
   Header — title + unread badge + Mark All Read
══════════════════════════════════════════════════════════ *@
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">

    <div>
        <h4 class="fw-bold mb-0" style="color:var(--sa-blue);">
            <i class="bi bi-bell-fill me-2" style="color:var(--sa-gold);"></i>
            My Notifications
            @if (unreadCount > 0)
            {
                <span class="badge rounded-pill ms-2"
                      style="background:var(--sa-danger);font-size:0.7rem;">
                    @unreadCount unread
                </span>
            }
        </h4>
        <p class="text-muted small mb-0 mt-1">
            Service request updates appear here in real time.
        </p>
    </div>

    @if (Model.Any(n => !n.IsRead))
    {
        <form asp-action="MarkAllRead" asp-controller="Notifications" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-check2-all me-1"></i>Mark All as Read
            </button>
        </form>
    }

</div>

@* ══════════════════════════════════════════════════════════
   Empty state
══════════════════════════════════════════════════════════ *@
@if (!Model.Any())
{
    <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
            <span class="empty-icon">
                <i class="bi bi-bell-slash" style="font-size:4rem;color:var(--light-gray);"></i>
            </span>
            <h5 class="text-muted mt-4 mb-1">No notifications yet</h5>
            <p class="text-muted small mb-4">
                When your service request status changes, you'll be notified here.
            </p>
            <a asp-controller="ServiceRequests" asp-action="Index"
               class="btn btn-sm"
               style="background:var(--sa-blue);color:var(--text-invert);">
                <i class="bi bi-clipboard2-check me-1"></i>View My Requests
            </a>
        </div>
    </div>
}
else
{
    @* ══════════════════════════════════════════════════════════
       Notification cards
    ══════════════════════════════════════════════════════════ *@
    <div class="d-flex flex-column gap-3">
        @foreach (var notification in Model)
        {
            <div class="card shadow-sm border-0 notif-card @(notification.IsRead ? "notif-read" : "notif-unread")">
                <div class="card-body d-flex justify-content-between align-items-start gap-3">

                    @* Left — icon + message + timestamp + view request link *@
                    <div class="d-flex gap-3 align-items-start flex-grow-1">

                        <div class="mt-1">
                            @if (!notification.IsRead)
                            {
                                <i class="bi bi-bell-fill fs-5" style="color:var(--sa-gold);"></i>
                            }
                            else
                            {
                                <i class="bi bi-bell fs-5 text-muted"></i>
                            }
                        </div>

                        <div>
                            <p class="mb-1 @(notification.IsRead ? "text-muted" : "fw-semibold")">
                                @notification.Message
                            </p>
                            <small class="text-muted">
                                <i class="bi bi-clock me-1"></i>
                                @notification.CreatedAt.ToString("dd MMM yyyy, HH:mm")
                            </small>

                            @if (notification.ServiceRequestId != null)
                            {
                                <div class="mt-2">
                                    <a asp-controller="ServiceRequests"
                                       asp-action="Details"
                                       asp-route-id="@notification.ServiceRequestId"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye me-1"></i>View Request
                                    </a>
                                </div>
                            }
                        </div>

                    </div>

                    @* Right — Mark Read + Delete *@
                    <div class="d-flex flex-column gap-2 align-items-end">

                        @if (!notification.IsRead)
                        {
                            <form asp-action="MarkRead"
                                  asp-controller="Notifications"
                                  asp-route-id="@notification.Id"
                                  method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-sm btn-outline-secondary"
                                        title="Mark as read">
                                    <i class="bi bi-check2"></i>
                                </button>
                            </form>
                        }

                        <form id="deleteNotifForm_@notification.Id"
                              asp-action="Delete"
                              asp-controller="Notifications"
                              asp-route-id="@notification.Id"
                              method="post"
                              style="display:none;">
                            @Html.AntiForgeryToken()
                        </form>
                        <button type="button"
                                class="btn btn-sm btn-outline-danger sa-delete-notif"
                                data-id="@notification.Id"
                                title="Delete notification">
                            <i class="bi bi-trash"></i>
                        </button>

                    </div>

                </div>
            </div>
        }
    </div>
}

@section Scripts {
<script>
    // SweetAlert2 — notification delete (carried over from Step 5)
    document.querySelectorAll('.sa-delete-notif').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var id = this.getAttribute('data-id');
            Swal.fire({
                title: 'Delete Notification?',
                text: 'This notification will be permanently removed.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#C53030',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, delete it',
                cancelButtonText: 'Cancel'
            }).then(function (result) {
                if (result.isConfirmed) {
                    document.getElementById('deleteNotifForm_' + id).submit();
                }
            });
        });
    });
</script>
}
