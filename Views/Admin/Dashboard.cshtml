@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Admin Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold" style="color: #002395;">
        <i class="bi bi-speedometer2 me-2"></i>Admin Dashboard
    </h1>
    <span class="text-muted">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</span>
</div>

<!-- Stats Grid -->
<div class="row g-4 mb-5">

    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100" style="border-left: 5px solid #002395 !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:56px;height:56px;background:#002395;">
                    <i class="bi bi-people-fill text-white fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Users</div>
                    <div class="fw-bold fs-3">@ViewData["TotalUsers"]</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:56px;height:56px;background:#007A4D;">
                    <i class="bi bi-person-vcard-fill text-white fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Citizens</div>
                    <div class="fw-bold fs-3">@ViewData["TotalCitizens"]</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:56px;height:56px;background:#C9A227;">
                    <i class="bi bi-person-badge-fill text-white fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Staff</div>
                    <div class="fw-bold fs-3">@ViewData["TotalStaff"]</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:56px;height:56px;background:#6c757d;">
                    <i class="bi bi-file-earmark-text-fill text-white fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Reports</div>
                    <div class="fw-bold fs-3">@ViewData["TotalReports"]</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:56px;height:56px;background:#C9A227;">
                    <i class="bi bi-hourglass-split text-white fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Pending Requests</div>
                    <div class="fw-bold fs-3">@ViewData["PendingRequests"]</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:56px;height:56px;background:#002395;">
                    <i class="bi bi-arrow-repeat text-white fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">In Progress</div>
                    <div class="fw-bold fs-3">@ViewData["InProgressRequests"]</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:56px;height:56px;background:#007A4D;">
                    <i class="bi bi-check-circle-fill text-white fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Completed Requests</div>
                    <div class="fw-bold fs-3">@ViewData["CompletedRequests"]</div>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- Quick Links -->
<h5 class="fw-semibold mb-3" style="color:#002395;">Quick Links</h5>
<div class="row g-3">

    <div class="col-md-3">
        <a asp-controller="Admin" asp-action="Users"
           class="card shadow-sm border-0 text-decoration-none h-100 d-block p-3 text-center"
           style="background:#002395;color:white;">
            <i class="bi bi-people fs-2"></i>
            <div class="mt-2 fw-semibold">User Management</div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="Admin" asp-action="CreateStaff"
           class="card shadow-sm border-0 text-decoration-none h-100 d-block p-3 text-center"
           style="background:#007A4D;color:white;">
            <i class="bi bi-person-plus fs-2"></i>
            <div class="mt-2 fw-semibold">Create Staff Account</div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="Citizens" asp-action="Index"
           class="card shadow-sm border-0 text-decoration-none h-100 d-block p-3 text-center"
           style="background:#C9A227;color:white;">
            <i class="bi bi-person-vcard fs-2"></i>
            <div class="mt-2 fw-semibold">Citizens</div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="ServiceRequests" asp-action="Index"
           class="card shadow-sm border-0 text-decoration-none h-100 d-block p-3 text-center"
           style="background:#6c757d;color:white;">
            <i class="bi bi-clipboard2-check fs-2"></i>
            <div class="mt-2 fw-semibold">Service Requests</div>
        </a>
    </div>

</div>
