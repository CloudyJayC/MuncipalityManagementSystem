@model MunicipalityManagementSystem.Models.ServiceRequest

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Cancel Service Request";
}

<div class="container mt-4">
    <div class="card shadow-sm p-4">
        <h2 class="text-warning mb-3">
            <i class="bi bi-x-circle"></i> Cancel Service Request
        </h2>
        <p class="lead">Are you sure you want to cancel this request?</p>

        <table class="table table-bordered mt-3">
            <tr>
                <th>Service Type</th>
                <td>@Model.ServiceType</td>
            </tr>
            <tr>
                <th>Request Date</th>
                <td>@Model.RequestDate.ToShortDateString()</td>
            </tr>
            <tr>
                <th>Status</th>
                <td><span class="badge bg-warning text-dark">@Model.Status</span></td>
            </tr>
        </table>

        <form asp-action="Cancel">
            <input type="hidden" asp-for="RequestID" />
            <button type="submit" class="btn btn-warning">
                <i class="bi bi-x-circle"></i> Yes, Cancel Request
            </button>
            <a asp-action="Index" class="btn btn-secondary ms-2">
                <i class="bi bi-arrow-left"></i> No, Go Back
            </a>
        </form>
    </div>
</div>
