@model IEnumerable<MunicipalityManagementSystem.Models.Citizen>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Citizens Management";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="mb-0">Citizens Directory</h1>
            <p class="text-secondary mt-1">Manage and view all registered citizens</p>
        </div>
        <div class="col-md-4 text-end">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-success">
                    <i class="bi bi-person-plus"></i> Add New Citizen
                </a>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="p-4 text-center">
                    <p class="text-secondary mb-0">
                        No citizens found.
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Create">Create one now</a>
                        }
                    </p>
                </div>
            }
            else
            {
                <table id="dataTable" class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Full Name</th>
                            <th>Address</th>
                            <th>Phone Number</th>
                            <th>Email</th>
                            <th>Date of Birth</th>
                            <th>Registration Date</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.FullName</strong></td>
                                <td>@item.Address</td>
                                <td>@item.PhoneNumber</td>
                                <td><a href="mailto:@item.Email">@item.Email</a></td>
                                <td>@item.DateOfBirth?.ToShortDateString()</td>
                                <td>@item.RegistrationDate.ToShortDateString()</td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.CitizenID" class="btn btn-sm btn-secondary" title="View details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.CitizenID" class="btn btn-sm btn-primary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <form id="deleteCitizenForm_@item.CitizenID" asp-action="Delete" asp-route-id="@item.CitizenID" method="post" style="display: none;">
                                                @Html.AntiForgeryToken()
                                            </form>
                                            <button type="button" class="btn btn-sm btn-danger sa-delete-citizen" data-id="@item.CitizenID" data-name="@item.FullName" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {
            $("#dataTable").DataTable({
                pageLength: 10,
                language: {
                    search: "Search citizens:",
                    lengthMenu: "Show _MENU_ citizens",
                    info: "Showing _START_ to _END_ of _TOTAL_ citizens",
                    emptyTable: "No citizens found."
                },
                columnDefs: [
                    { orderable: false, targets: -1 }
                ]
            });
        });

        // SweetAlert2 for citizen deletion
        document.querySelectorAll('.sa-delete-citizen').forEach(function(button) {
            button.addEventListener('click', function(e) {
                e.preventDefault();
                const citizenId = this.getAttribute('data-id');
                const citizenName = this.getAttribute('data-name');

                Swal.fire({
                    title: 'Delete Citizen?',
                    text: 'You are about to delete ' + citizenName + '. This cannot be undone.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#C53030',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, delete it',
                    cancelButtonText: 'Cancel'
                }).then(function(result) {
                    if (result.isConfirmed) {
                        document.getElementById('deleteCitizenForm_' + citizenId).submit();
                    }
                });
            });
        });
    </script>
}
