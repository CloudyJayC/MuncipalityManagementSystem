@page
@model LoginModel

@{
    ViewData["Title"] = "Sign In";
    Layout = "/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        .login-wrapper {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
        }

            .login-card .card-header {
                padding: 1.5rem 1.75rem 1.25rem;
            }

            .login-card .card-body {
                padding: 1.75rem;
            }

            .login-card .card-footer {
                padding: 1rem 1.75rem;
                background: #f8f9fa;
            }

            .login-card .form-control {
                border-radius: 6px;
                font-size: 0.95rem;
                padding: 0.6rem 0.85rem;
            }

                .login-card .form-control:focus {
                    border-color: var(--sa-blue);
                    box-shadow: 0 0 0 0.2rem rgba(0, 35, 149, 0.15);
                }

        .btn-login {
            background: var(--sa-blue);
            color: #fff;
            border: none;
            border-radius: 6px;
            font-weight: 600;
            letter-spacing: 0.3px;
            padding: 0.65rem 1rem;
            transition: background 0.2s ease;
        }

            .btn-login:hover {
                background: #001a70;
                color: #fff;
            }
    </style>
}

<div class="login-wrapper">
    <div class="login-card">
        <div class="card shadow-sm border-0">

            @* ── Card Header ── *@
            <div class="card-header text-white" style="background: var(--sa-blue); border-radius: 8px 8px 0 0;">
                <div class="d-flex align-items-center gap-3">
                    <i class="bi bi-building-fill" style="font-size: 2rem; color: var(--sa-gold);"></i>
                    <div>
                        <h5 class="mb-0 fw-bold" style="color: #fff;">Municipality Management System</h5>
                        <small style="color: rgba(255,255,255,0.75);">Sign in to your account</small>
                    </div>
                </div>
            </div>

            @* ── Card Body ── *@
            <div class="card-body">

                @* Validation errors *@
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                <form id="account" method="post">

                    @* Email *@
                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label fw-semibold small">
                            <i class="bi bi-envelope me-1"></i>Email Address
                        </label>
                        <input asp-for="Input.Email"
                               class="form-control"
                               autocomplete="username"
                               aria-required="true"
                               placeholder="you@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    @* Password *@
                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label fw-semibold small">
                            <i class="bi bi-lock me-1"></i>Password
                        </label>
                        <input asp-for="Input.Password"
                               class="form-control"
                               autocomplete="current-password"
                               aria-required="true"
                               placeholder="Enter your password" />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    @* Remember Me + Forgot Password *@
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check mb-0">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label class="form-check-label small" asp-for="Input.RememberMe">
                                @Html.DisplayNameFor(m => m.Input.RememberMe)
                            </label>
                        </div>
                        <a asp-page="./ForgotPassword"
                               class="small text-decoration-none"
                               style="color: var(--sa-blue);">
                            Forgot password?
                        </a>
                    </div>

                    @* Submit *@
                    <button id="login-submit" type="submit" class="btn btn-login w-100">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                    </button>

                </form>
            </div>

            @* ── Card Footer ── *@
            <div class="card-footer text-center border-0">
                <span class="small text-muted">Don't have an account?</span>
                <a asp-page="./Register"
                       asp-route-returnUrl="@Model.ReturnUrl"
                       class="small fw-semibold ms-1 text-decoration-none"
                       style="color: var(--sa-green);">
                    Register here
                </a>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
